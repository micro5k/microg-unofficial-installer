{
    "version": "2.0.0",
    "presentation": {
        "reveal": "always",
        "revealProblems": "onProblem"
    },
    "problemMatcher": [
        {
            "owner": "custom-shell-output",
            "fileLocation": "search",
            "pattern": [
                {
                    "regexp": "^([^:]+):(\\d+):\\s+(ERROR|WARNING):\\s+\\[([^\\]]*)\\]\\s+(.*)\\r?$",
                    "file": 1,
                    "line": 2,
                    "severity": 3,
                    "code": 4,
                    "message": 5
                }
            ]
        }
    ],
    "tasks": [
        {
            "label": "buildOta",
            "icon": { "id": "rocket", "color": "terminal.ansiCyan" },
            "detail": "Build the flashable zip [Full edition].",
            "type": "shell",
            "command": "${workspaceFolder}/build.sh",
            "windows": {
                "command": "${workspaceFolder}\\build.bat"
            },
            "options": {
                "env": {
                    "BUILD_TYPE": "full"
                }
            },
            "group": "build"
        },
        {
            "label": "buildOtaOSS",
            "icon": { "id": "rocket", "color": "terminal.ansiGreen" },
            "detail": "Build the flashable zip [OSS edition].",
            "type": "shell",
            "command": "${workspaceFolder}/build.sh",
            "windows": {
                "command": "${workspaceFolder}\\build.bat"
            },
            "options": {
                "env": {
                    "BUILD_TYPE": "oss"
                }
            },
            "group": "build"
        },
        {
            "label": "installTest",
            "icon": { "id": "beaker", "color": "terminal.ansiYellow" },
            "detail": "Test the flashable zip in a simulated Android recovery environment on your PC.",
            "type": "shell",
            "command": "${workspaceFolder}/recovery-simulator/recovery.sh",
            "args": ["${workspaceFolder}/output/*.zip"],
            "windows": {
                "command": "${workspaceFolder}\\recovery-simulator\\recovery.bat",
                "args": ["${workspaceFolder}\\output\\*.zip"]
            },
            "options": {
                "env": {
                    "BB_GLOBBING": "1"
                }
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "panel": "dedicated"
            }
        },
        {
            "label": "reuse-lint",
            "icon": { "id": "law", "color": "terminal.ansiMagenta" },
            "detail": "Verify license and copyright compliance (REUSE).",
            "type": "shell",
            "command": "reuse",
            "args": ["lint"],
            "problemMatcher": []
        }
    ]
}
