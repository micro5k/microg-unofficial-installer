/.bundle/
/.cache/
/.git/
/.gnupg/
/.licenses/
/.ssh/
/coverage/
/dependency-graph-reports/
/node_modules/
/vendor/

/.ash_history
/.bash_history
/.lesshst
/.wget-hsts
__pycache__/
.mypy_cache/
.DS_Store
Thumbs.db
desktop.ini
*.dex
*.log
*.sarif

/package.json
/package-lock.json

/.gitconfig

# VS Code files
/.vscode/launch.json

# Git hooks
/.git-hooks/post-checkout
/.git-hooks/post-commit
/.git-hooks/post-merge
/.git-hooks/pre-push

# Gradle files
/.gradle/
/build/
/gradle/gradle-daemon-jvm.properties

